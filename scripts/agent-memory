#!/usr/bin/env python3
"""agent-memory — CLI for the Agent Memory Framework.

Usage:
    agent-memory init          Initialize .ai/ memory files in current repo
    agent-memory validate      Check all .ai/ files exist and have valid content
    agent-memory compress      Compress bloated memory files (auto-summarize)
    agent-memory context       Build compact context pack for a task
    agent-memory finish        Update core memory after a task

Install as:
    chmod +x scripts/agent-memory
    ln -s "$(pwd)/scripts/agent-memory" /usr/local/bin/agent-memory
"""

# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

