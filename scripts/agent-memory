# ── Helpers ────────────────────────────────────────────────────────────────

def _root() -> Path:
    """Find repo root (where AGENTS.md lives)."""
    cwd = Path.cwd()
    for parent in [cwd] + list(cwd.parents):
        if (parent / "AGENTS.md").exists():
            return parent
    print("Error: No AGENTS.md found. Are you in the repo root?", file=sys.stderr)
    sys.exit(1)


def _info(msg: str):
    print(f"  ✓ {msg}")


def _warn(msg: str):
    print(f"  ⚠ {msg}")


def _err(msg: str):
    print(f"  ✗ {msg}")


# ── Subcommands ────────────────────────────────────────────────────────────

def cmd_init(args):
    """Initialize .ai/ memory files and git hook."""
    root = _root()
    ai_dir = root / ".ai"
    ai_dir.mkdir(parents=True, exist_ok=True)

    created = 0
    skipped = 0

    for fname, content in TEMPLATES.items():
        path = ai_dir / fname
        if path.exists():
            _warn(f"{fname} already exists")
            skipped += 1
        else:
            path.write_text(content.strip() + "\n", encoding="utf-8")
            _info(f"Created .ai/{fname}")
            created += 1

    # Init graph-memory.yaml as structured format (replace .md if exists)
    md_graph = ai_dir / "graph-memory.md"
    yaml_graph = ai_dir / "graph-memory.yaml"
    if md_graph.exists() and not yaml_graph.exists():
        # Migrate: import old graph-memory.md content
        old_content = md_graph.read_text(encoding="utf-8")
        yaml_graph.write_text(TEMPLATES["graph-memory.yaml"].strip() + "\n", encoding="utf-8")
        _info("Created .ai/graph-memory.yaml (migrated from .md format)")
        # Keep old .md as reference but note it's deprecated
        md_graph.rename(ai_dir / "graph-memory.md.deprecated")

    # Install git pre-commit hook
    hooks_dir = root / ".githooks"
    hooks_dir.mkdir(parents=True, exist_ok=True)
    hook_path = hooks_dir / "pre-commit"
    if not hook_path.exists():
        hook_content = _precommit_hook_script()
        hook_path.write_text(hook_content.strip() + "\n", encoding="utf-8")
        hook_path.chmod(0o755)
        _info("Created .githooks/pre-commit — run 'git config core.hooksPath .githooks' to enable")
    else:
        _warn(".githooks/pre-commit already exists")

    print(f"\nDone: {created} files created, {skipped} already existed")
    print("Run 'git config core.hooksPath .githooks' to enable pre-commit validation.")


def cmd_validate(args):
    """Validate all required .ai/ files exist and have content."""
    root = _root()
    errors = 0
    warnings = 0

    # Check AGENTS.md
    agents = root / "AGENTS.md"
    if not agents.exists():
        _err("Missing required: AGENTS.md")
        errors += 1
    elif not agents.read_text(encoding="utf-8").strip():
        _err("Empty file: AGENTS.md")
        errors += 1
    else:
        _info("AGENTS.md present")

    # Check required .ai/ files
    for rel in REQUIRED_FILES:
        path = root / rel
        if not path.exists():
            _err(f"Missing required: {rel}")
            errors += 1
            continue
        text = path.read_text(encoding="utf-8", errors="replace").strip()
        if not text:
            _err(f"Empty file: {rel}")
            errors += 1
        elif text == TEMPLATES.get(rel.split("/")[-1], "").strip():
            _warn(f"Unchanged template: {rel} — fill in project-specific details")
            warnings += 1
        else:
            _info(f"{rel} — {len(text)} bytes, non-empty")

    # Check recommended .ai/ files
    for rel in RECOMMENDED_FILES:
        path = root / rel
        if not path.exists():
            _warn(f"Recommended but missing: {rel}")
            warnings += 1

    # Check skill files
    skill_base = root / "skills" / "memory-framework"
    for skill in SKILL_DIRS:
        sp = skill_base / skill / "SKILL.md"
        if not sp.exists():
            _warn(f"Missing skill: {skill}/SKILL.md")
            warnings += 1

    # Check .githooks
    hook_path = root / ".githooks" / "pre-commit"
    hook_enabled = False
    if hook_path.exists() and os.access(str(hook_path), os.X_OK):
        _info(".githooks/pre-commit hook present and executable")
        # Check if hooksPath is configured
        import subprocess
        result = subprocess.run(
            ["git", "config", "core.hooksPath"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0 and result.stdout.strip() == ".githooks":
            hook_enabled = True
            _info("Pre-commit hook enabled (core.hooksPath = .githooks)")
        else:
            _warn("Pre-commit hook installed but not enabled. Run: git config core.hooksPath .githooks")
    else:
        _warn("No pre-commit hook at .githooks/pre-commit — consider creating one")

    # Summary
    print(f"\n{'─' * 40}")
    if errors:
        print(f"RESULT: {errors} ERRORS, {warnings} warnings — fix errors before committing")
    elif warnings:
        print(f"RESULT: PASSED with {warnings} warnings")
    else:
        print("RESULT: ALL CHECKS PASSED")

    return errors


def cmd_compress(args):
    """Compress memory files: deduplicate, truncate old entries, keep current state."""
    root = _root()

    files_to_compress = [
        ".ai/agent-handoff.md", ".ai/current-state.md",
        ".ai/bugs-and-fixes.md", ".ai/session-log.md", ".ai/task-board.md",
    ]

    for rel in files_to_compress:
        path = root / rel
        if not path.exists():
            _warn(f"Skipping {rel} — not found")
            continue

        text = path.read_text(encoding="utf-8")
        original_len = len(text)
        lines = text.splitlines()

        # Skip empty files
        if original_len < 50:
            _info(f"{rel} — already small ({original_len} bytes), skipping")
            continue

        # Compression heuristics:
        new_lines = []
        dedup_set = set()
        empty_line_run = 0
        kept = 0
        removed = 0

        for line in lines:
            stripped = line.strip()

            # Collapse repeated empty lines
            if not stripped:
                empty_line_run += 1
                if empty_line_run <= 1:
                    new_lines.append(line)
                else:
                    removed += 1
                continue
            empty_line_run = 0

            # Deduplicate exact repeated lines
            if stripped in dedup_set and len(stripped) > 20:
                removed += 1
                continue
            dedup_set.add(stripped)

            new_lines.append(line)
            kept += 1

        new_text = "\n".join(new_lines)
        new_len = len(new_text)

        saved = original_len - new_len
        if saved > 0:
            path.write_text(new_text + "\n", encoding="utf-8")
            _info(f"{rel} — compressed: {original_len} → {new_len} bytes ({saved} saved, {removed} lines removed)")
        else:
            _info(f"{rel} — already clean ({original_len} bytes)")

    print("\nCompression complete.")


# ── Pre-commit hook content ────────────────────────────────────────────────

def _precommit_hook_script() -> str:
    return """#!/usr/bin/env python3
""" + '''
"""Pre-commit hook: validate Agent Memory Framework files."""

import subprocess
import sys
from pathlib import Path

def main():
    # Use the agent-memory CLI if available
    script = Path(__file__).resolve().parent.parent / "scripts" / "agent-memory"
    if script.exists():
        result = subprocess.run(
            [sys.executable, str(script), "validate"],
            capture_output=True, text=True, timeout=30
        )
        print(result.stdout)
        if "ERROR" in result.stdout:
            print("\\nCommit blocked: fix memory files before committing.")
            print("Run: agent-memory init  (to create missing files)")
            print("     agent-memory validate (to check again)")
            sys.exit(1)
        if result.stderr:
            print(result.stderr, file=sys.stderr)
    else:
        # Fallback: basic check — [rest unchanged]
        root = Path.cwd()
        required = [
            "AGENTS.md",
            ".ai/project-brief.md", ".ai/current-state.md",
            ".ai/decisions.md", ".ai/task-board.md",
        ]
        errors = 0
        for rel in required:
            if not (root / rel).exists():
                print(f"ERROR: Missing {rel}")
                errors += 1
        if errors:
            sys.exit(1)

if __name__ == "__main__":
    main()
'''


# ── Retrieval Commands ─────────────────────────────────────────────────────

def cmd_index(args):
    """Build the BM25 search index for .ai/ memory files."""
    try:
        from memory_query import MemoryIndex
    except ImportError:
        sys.path.insert(0, str(Path(__file__).resolve().parent))
        from memory_query import MemoryIndex

    root = _root()
    ai_dir = root / ".ai"
    idx = MemoryIndex(str(ai_dir))
    idx.build(force=True)
    print(f"Indexed {idx.num_docs} documents ({len(idx.idf)} unique terms)")
    print(f"Cache: {ai_dir / '.memory_index' / 'index.json'}")


def cmd_query(args):
    """BM25 search query against .ai/ memory files."""
    try:
        from memory_query import MemoryIndex, format_results
    except ImportError:
        sys.path.insert(0, str(Path(__file__).resolve().parent))
        from memory_query import MemoryIndex, format_results

    root = _root()
    ai_dir = root / ".ai"
    idx = MemoryIndex(str(ai_dir))
    idx.build()
    results = idx.query(args.terms, top_k=args.top_k)
    print(format_results(results, mode="query"))


def cmd_search(args):
    """Search for files containing specific terms (grep-like)."""
    try:
        from memory_query import MemoryIndex, format_results
    except ImportError:
        sys.path.insert(0, str(Path(__file__).resolve().parent))
        from memory_query import MemoryIndex, format_results

    root = _root()
    ai_dir = root / ".ai"
    idx = MemoryIndex(str(ai_dir))
    idx.build()
    results = idx.search(args.term)
    print(format_results(results, mode="search"))


def cmd_import_(args):
    """Bootstrap .ai/ files from an existing project."""
    try:
        from memory_query.importer import import_cli
    except ImportError:
        sys.path.insert(0, str(Path(__file__).resolve().parent))
        from memory_query.importer import import_cli

    return import_cli(args)


# ── Suggest ────────────────────────────────────────────────────────────────

def cmd_suggest(args):
    """Suggest memory updates based on recent git changes."""
    root = _root()

    # Get files changed in the last commit
    result = subprocess.run(
        ["git", "diff", "--name-only", "HEAD~1", "HEAD"],
        capture_output=True, text=True, timeout=30, cwd=root
    )
    if result.returncode != 0:
        # Try just unstaged changes
        result = subprocess.run(
            ["git", "diff", "--name-only"],
            capture_output=True, text=True, timeout=30, cwd=root
        )

    changed = [f.strip() for f in result.stdout.splitlines() if f.strip()]
    if not changed:
        print("No recent changes detected.")
        return

    # Analyze what changed
    ai_updated = any(f.startswith(".ai/") for f in changed)
    source_changed = [f for f in changed if not f.startswith(".ai/") and f.endswith((".py", ".js", ".ts", ".go", ".rs", ".rb", ".java", ".yaml", ".yml"))]

    suggestions = []
    if source_changed:
        suggestions.append("Update .ai/current-state.md (source files changed)")
        suggestions.append("Update .ai/task-board.md (work was done)")
        suggestions.append("Update .ai/agent-handoff.md (session summary)")
        suggestions.append("Update .ai/graph-memory.yaml (relationships may have changed)")

    if any("test" in f.lower() for f in changed):
        suggestions.append("Update .ai/test-results.md (tests changed)")

    if any(f.endswith((".yaml", ".yml", ".json", ".toml")) for f in changed):
        suggestions.append("Update .ai/dependencies.md (config/deps changed)")

    if any(".env" in f or "credential" in f.lower() or "secret" in f.lower() for f in changed):
        suggestions.append("CRITICAL: Check .ai/security.md (secrets/credentials may have been exposed)")

    if not ai_updated:
        suggestions.append("(.ai/ files were NOT updated — memory may be stale)")

    print(f"Detected {len(changed)} changed files:\n")
    for f in changed[:15]:
        print(f"  {f}")
    if len(changed) > 15:
        print(f"  ... and {len(changed)-15} more")
    print(f"\nSuggested memory updates:\n")
    for s in suggestions:
        icon = "!" if s.startswith("CRITICAL") else "•"
        print(f"  {icon} {s}")


# ── Context Pack ───────────────────────────────────────────────────────────

_ALWAYS_CONTEXT_FILES = [
    ".ai/agent-handoff.md",
    ".ai/current-state.md",
    ".ai/task-board.md",
]


def _read_rel(root: Path, rel: str) -> str:
    path = root / rel
    if not path.exists():
        return ""
    return path.read_text(encoding="utf-8", errors="replace").strip()


def _truncate_for_budget(text: str, max_chars: int) -> str:
    if len(text) <= max_chars:
        return text
    keep = max(120, max_chars - 40)
    return text[:keep].rstrip() + "\n[truncated]"


def _render_context_file(root: Path, rel: str, max_chars: int) -> str:
    text = _read_rel(root, rel)
    if not text:
        return f"### {rel}\nMissing or empty."
    return f"### {rel}\n{_truncate_for_budget(text, max_chars)}"


def cmd_context(args):
    """Build a compact context pack for a task without reading all memory files."""
    try:
        from memory_query import MemoryIndex
    except ImportError:
        sys.path.insert(0, str(Path(__file__).resolve().parent))
        from memory_query import MemoryIndex

    root = _root()
    ai_dir = root / ".ai"
    idx = MemoryIndex(str(ai_dir))
    idx.build()

    budget = max(args.budget, 200)
    # Approximate four characters per token. Split budget across always-read files
    # and relevant snippets so the pack stays bounded without external tokenizers.
    total_chars = budget * 4
    per_file_chars = max(220, total_chars // max(args.top_k + len(_ALWAYS_CONTEXT_FILES) + 2, 1))

    results = idx.query(args.task, top_k=max(args.top_k + len(_ALWAYS_CONTEXT_FILES), args.top_k))
    always = [rel for rel in _ALWAYS_CONTEXT_FILES if (root / rel).exists()]
    always_set = set(always)
    relevant = []
    for result in results:
        rel = result["path"]
        if rel in always_set:
            continue
        relevant.append(result)
        if len(relevant) >= args.top_k:
            break

    lines = [
        "# Agent Memory Context Pack",
        "",
        f"Task: {args.task}",
        f"Budget: ~{budget} tokens",
        "",
        "## Always Included",
    ]

    if always:
        for rel in always:
            lines.append(_render_context_file(root, rel, per_file_chars))
            lines.append("")
    else:
        lines.append("No standard memory files found.")
        lines.append("")

    lines.append("## Relevant Memory")
    if relevant:
        for result in relevant:
            rel = result["path"]
            snippet = result.get("snippet", "") or _read_rel(root, rel)
            snippet = _truncate_for_budget(snippet.strip(), per_file_chars)
            lines.append(f"### {rel} (score: {result['score']})")
            lines.append(snippet or "No snippet available.")
            lines.append("")
    else:
        lines.append("No additional relevant memory found.")
        lines.append("")

    files_to_read = always + [r["path"] for r in relevant]
    lines.append("## Files To Read Fully")
    for rel in files_to_read:
        lines.append(f"- {rel}")

    print("\n".join(lines).rstrip())


# ── Finish Session ─────────────────────────────────────────────────────────


def _git_changed_files(root: Path) -> list[str]:
    """Return changed and untracked file paths relative to repo root."""
    commands = [
        ["git", "diff", "--name-only", "HEAD"],
        ["git", "diff", "--cached", "--name-only"],
        ["git", "ls-files", "--others", "--exclude-standard"],
    ]
    changed: list[str] = []
    for cmd in commands:
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=10, cwd=root)
        except (subprocess.TimeoutExpired, FileNotFoundError):
            continue
        if result.returncode == 0:
            changed.extend(f.strip() for f in result.stdout.splitlines() if f.strip())
    return sorted(set(changed))


def _append_section(path: Path, title: str, lines: list[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    existing = path.read_text(encoding="utf-8", errors="replace").rstrip() if path.exists() else f"# {path.stem}\n"
    body = "\n".join(lines).rstrip()
    path.write_text(f"{existing}\n\n## {title}\n\n{body}\n", encoding="utf-8")


def _bullet_list(items: list[str], empty: str = "None detected.") -> list[str]:
    if not items:
        return [f"- {empty}"]
    return [f"- `{item}`" for item in items]


def cmd_finish(args):
    """Update core memory files at task end and rebuild retrieval index."""
    root = _root()
    ai_dir = root / ".ai"
    ai_dir.mkdir(parents=True, exist_ok=True)
    today = datetime.now().strftime("%Y-%m-%d")
    changed = _git_changed_files(root)
    next_task = args.next or "TBD"

    handoff_lines = [
        f"- Summary: {args.summary}",
        f"- Next: {next_task}",
        "- Changed files:",
        *_bullet_list(changed),
    ]
    _append_section(ai_dir / "agent-handoff.md", f"{today} — Finish", handoff_lines)
    print("Updated .ai/agent-handoff.md")

    current_lines = [
        f"- Latest progress: {args.summary}",
        f"- Next recommended task: {next_task}",
        f"- Last updated: {today}",
    ]
    _append_section(ai_dir / "current-state.md", f"{today} — Latest Progress", current_lines)
    print("Updated .ai/current-state.md")

    task_lines = [
        "### Done",
        f"- {args.summary}",
        "",
        "### Next",
        f"- {next_task}",
    ]
    _append_section(ai_dir / "task-board.md", f"{today} — Task Update", task_lines)
    print("Updated .ai/task-board.md")

    try:
        from memory_query import MemoryIndex
    except ImportError:
        sys.path.insert(0, str(Path(__file__).resolve().parent))
        from memory_query import MemoryIndex
    idx = MemoryIndex(str(ai_dir))
    idx.build(force=True)
    print(f"Rebuilt memory index ({idx.num_docs} documents)")


# ── Main ───────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Agent Memory Framework CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Examples:
  agent-memory init            Initialize .ai/ files in current repo
  agent-memory validate        Check memory file integrity
  agent-memory compress        Reduce bloat in memory files
  agent-memory context "task"  Build compact context pack for a task
  agent-memory finish --summary "done"  Update memory after a task
  agent-memory index           Build BM25 search index
  agent-memory query "terms"   BM25 search (ranked results)
  agent-memory search <term>   Find files containing term
  agent-memory import <path>   Bootstrap .ai/ from existing project
  agent-memory suggest         Suggest memory updates from git changes
        """,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    init_p = sub.add_parser("init", help="Initialize .ai/ memory files")
    init_p.set_defaults(func=cmd_init)

    val_p = sub.add_parser("validate", help="Validate memory file integrity")
    val_p.set_defaults(func=cmd_validate)

    comp_p = sub.add_parser("compress", help="Compress bloated memory files")
    comp_p.set_defaults(func=cmd_compress)

    ctx_p = sub.add_parser("context", help="Build compact context pack for a task")
    ctx_p.add_argument("task", help="Task description to retrieve relevant memory for")
    ctx_p.add_argument("-k", "--top-k", type=int, default=3, help="Relevant memory files to include (default: 3)")
    ctx_p.add_argument("--budget", type=int, default=4000, help="Approximate token budget (default: 4000)")
    ctx_p.set_defaults(func=cmd_context)

    fin_p = sub.add_parser("finish", help="Update core memory after a task")
    fin_p.add_argument("--summary", required=True, help="Concise summary of completed work")
    fin_p.add_argument("--next", default="", help="Recommended next task")
    fin_p.set_defaults(func=cmd_finish)

    idx_p = sub.add_parser("index", help="Build BM25 search index for .ai/ files")
    idx_p.set_defaults(func=cmd_index)

    q_p = sub.add_parser("query", help="BM25 search query against indexed memory")
    q_p.add_argument("terms", help="Search terms (e.g. 'database schema auth')")
    q_p.add_argument("-k", "--top-k", type=int, default=5, help="Number of results (default: 5)")
    q_p.set_defaults(func=cmd_query)

    s_p = sub.add_parser("search", help="Find .ai/ files containing a specific term")
    s_p.add_argument("term", help="Term to search for")
    s_p.set_defaults(func=cmd_search)

    imp_p = sub.add_parser("import", help="Bootstrap .ai/ files from existing project")
    imp_p.add_argument("path", nargs="?", default=".", help="Path to project (default: current dir)")
    imp_p.set_defaults(func=cmd_import_)

    sug_p = sub.add_parser("suggest", help="Suggest memory updates from recent git changes")
    sug_p.set_defaults(func=cmd_suggest)

    args = parser.parse_args()
    errors = args.func(args)
    if hasattr(errors, "__int__") and errors:
        sys.exit(1)


if __name__ == "__main__":
    main()
